# ========================================
# HotBoard 生产环境变量配置模板
# ========================================
# 复制此文件为 .env.production 并填写实际值
# 在 Vercel Dashboard 中配置这些环境变量

# ============ Supabase 数据库配置 ============
# 从 Supabase Dashboard > Settings > API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============ Tophub 数据 API ============
# 联系 TophubData 获取 API Key
# https://www.tophubdata.com/
TOPHUB_API_KEY=your-tophub-api-key

# ============ 应用基础配置 ============
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_NAME=HotBoard
NEXT_PUBLIC_APP_DESCRIPTION=全网热榜聚合平台

# ============ OAuth: Google 登录 ============
# 从 Google Cloud Console 获取
# https://console.cloud.google.com/apis/credentials
# 授权重定向 URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============ OAuth: GitHub 登录 ============
# 从 GitHub Settings > Developer settings > OAuth Apps 获取
# https://github.com/settings/developers
# 授权回调 URL: {NEXT_PUBLIC_APP_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============ 可选: 监控与分析 ============
# Sentry 错误追踪
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=hotboard

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============ 可选: 邮件服务 ============
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@your-domain.com

# ============ 可选: Redis 缓存 ============
# 需要 Vercel KV 或 Upstash Redis
# REDIS_URL=redis://xxx.upstash.io:6379
# REDIS_TOKEN=your-redis-token

# ============ 可选: 部署配置 ============
# Node.js 环境
NODE_ENV=production

# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# Vercel 自动设置的环境变量
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app
# VERCEL_GIT_PROVIDER=github
# VERCEL_GIT_REPO_SLUG=hotboard
# VERCEL_GIT_REPO_ID=xxx
# VERCEL_GIT_COMMIT_REF=main
# VERCEL_GIT_COMMIT_SHA=xxx
# VERCEL_GIT_COMMIT_MESSAGE=xxx
# VERCEL_REGION=hnd1

# ============ 可选: Cron Job 配置 ============
# Cron Job 密钥（用于验证定时任务请求）
# CRON_SECRET=your-random-secret-key

# ============ 可选: 功能开关 ============
# 启用用户认证系统
# ENABLE_AUTH=true

# 启用数据同步服务
# ENABLE_SYNC=true

# 启用实时更新（WebSocket）
# ENABLE_REALTIME=false

# ============ 可选: 性能优化 ============
# 数据缓存时间（秒）
# CACHE_TTL=3600

# API 请求超时（毫秒）
# API_TIMEOUT=10000

# 最大并发请求数
# MAX_CONCURRENT_REQUESTS=10

# ============ 可选: 安全配置 ============
# CORS 允许的源（逗号分隔）
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate Limiting
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000
