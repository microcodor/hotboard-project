{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "hotboard",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/cron/(.*)",
      "headers": {
        "Cache-Control": "no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "headers": {
        "Cache-Control": "s-maxage=60, stale-while-revalidate=300"
      },
      "continue": true
    },
    {
      "src": "/_next/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/images/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=86400, stale-while-revalidate=604800"
      },
      "continue": true
    }
  ],
  "regions": ["iad1", "hnd1", "sin1"],
  "functions": {
    "app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "app/api/cron/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "app/api/monitoring/**/*.ts": {
      "memory": 512,
      "maxDuration": 5
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/quality-check",
      "schedule": "0 */2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/hot/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/sources",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "HotBoard",
    "NEXT_PUBLIC_APP_DESCRIPTION": "全网热榜聚合平台"
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "github": {
    "silent": true,
    "autoJobCancelInCancel": true
  },
  "alias": ["hotboard.app"],
  "trailingSlash": false
}
