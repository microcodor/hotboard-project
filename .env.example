# HotBoard 环境变量配置
# 复制此文件为 .env.local 并修改对应值

# 数据库
DATABASE_URL=postgresql://hotboard:hotboard123@localhost:5432/hotboard
POSTGRES_PASSWORD=hotboard123

# JWT 密钥（生产环境务必修改为随机长字符串）
JWT_SECRET=hotboard-secret-change-me-in-production

# 管理员账号（首次启动自动创建）
ADMIN_EMAIL=admin@hotboard.com
ADMIN_PASSWORD=admin123456

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
